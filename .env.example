# ─── Trade Settlement Operations — Environment Configuration ───
# Copy to .env and adjust for your environment.
# All values shown are the defaults used when the variable is unset.

# ── Paths ──────────────────────────────────────────────────────
# SETTLE_DATA_DIR=data/generated
# SETTLE_CONFIG_DIR=config
# SETTLE_KB_DIR=data/knowledge_base

# ── Database ───────────────────────────────────────────────────
# SQLite (default for local dev):
# SETTLE_DATABASE_URL=sqlite:///data/generated/settlement.db
#
# PostgreSQL (production):
# SETTLE_DATABASE_URL=postgresql://user:password@localhost:5432/settlement

# ── Logging ────────────────────────────────────────────────────
# SETTLE_LOG_LEVEL=INFO
# SETTLE_LOG_FORMAT=json          # "json" for production, "console" for dev

# ── ML Model ──────────────────────────────────────────────────
# SETTLE_MODEL_PATH=data/generated/fail_predictor_model.pkl
# SETTLE_MODEL_HMAC_PATH=data/generated/fail_predictor_model.hmac
# SETTLE_MODEL_SIGNING_KEY=trade-settlement-model-integrity-v1

# ── Embedding / Knowledge Base ─────────────────────────────────
# SETTLE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Pipeline Tuning ───────────────────────────────────────────
# SETTLE_ML_RISK_THRESHOLD=0.3
# SETTLE_ML_TRAINING_SAMPLES=5000
# SETTLE_CSDR_BASE_RATE_BPS=1.0
# SETTLE_LIQUIDITY_BUFFER_INR=500000000

# ── Retry / Resilience ────────────────────────────────────────
# SETTLE_RETRY_MAX_ATTEMPTS=3
# SETTLE_RETRY_BASE_DELAY=1.0
# SETTLE_CB_THRESHOLD=5
# SETTLE_CB_RESET_TIMEOUT=60.0

# ── Dashboard ─────────────────────────────────────────────────
# SETTLE_DASHBOARD_PORT=8501

# ── Feature Flags (true/false) ────────────────────────────────
# SETTLE_ENABLE_ML=true
# SETTLE_ENABLE_CSDR=true
# SETTLE_ENABLE_ISO20022=true
# SETTLE_ENABLE_LIQUIDITY=true
# SETTLE_ENABLE_SCORECARDS=true
